<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Endpoint Security entitlement - required for file monitoring -->
    <!-- NOTE: This entitlement requires Apple approval for distribution -->
    <!-- For local testing with SIP disabled, this will work without approval -->
    <key>com.apple.developer.endpoint-security.client</key>
    <true/>
</dict>
</plist>
