{
    "enabled": true,
    "blocked_processes": [
        "opencode",
        "open-code",
        "opencode-agent"
    ],
    "blocked_paths": [
        "/Users",
        "/tmp",
        "/var",
        "/etc",
        "/private",
        "/Applications"
    ],
    "description": "Agent Gateway Enforcer - File Access Configuration",
    "notes": [
        "Copy this file to /etc/agent-gateway-enforcer/blocked.json",
        "The extension will reload configuration on restart"
    ]
}
